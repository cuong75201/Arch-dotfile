create proc spud_SoLuongSV
    @khoa NVARCHAR(100)
AS
BEGIN
    DECLARE @makhoa char(4), @count INT
    SELECT @makhoa = MAKHOA
    from dbo.KHOA
    where TENKHOA = @khoa
    SET @count = 0
    SELECT @count = COUNT(*)
    FROM dbo.SVIEN
    WHERE MAKHOA = @makhoa

    if @count < 100
    PRINT 'Can tuyen sinh them'
    ELSE
    PRINT 'Da tuyen sinh du'
END

EXEC spud_SoLuongSV @khoa = 'Toan'