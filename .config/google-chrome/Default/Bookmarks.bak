            "url": "javascript: (async function () {  let user_id = prompt(\"Enter user id:\", \"\");  if (!user_id) return;  function getBiggestMediaFromNode(node) {    if (node.is_video) {      return getUniversalCdnUrl(node.video_url);    } else {      let r = node.display_resources;      return r[r.length - 1]?.src;%20%20%20%20}%20%20}%20%20function%20download(data,%20filename,%20type)%20{%20%20%20%20var%20file%20=%20new%20Blob([data],%20{%20type:%20type%20});%20%20%20%20if%20(window.navigator.msSaveOrOpenBlob)%20%20%20%20%20%20window.navigator.msSaveOrOpenBlob(file,%20filename);%20%20%20%20else%20{%20%20%20%20%20%20var%20a%20=%20document.createElement(%22a%22),%20%20%20%20%20%20%20%20url%20=%20URL.createObjectURL(file);%20%20%20%20%20%20a.href%20=%20url;%20%20%20%20%20%20a.download%20=%20filename;%20%20%20%20%20%20document.body.appendChild(a);%20%20%20%20%20%20a.click();%20%20%20%20%20%20setTimeout(function%20()%20{%20%20%20%20%20%20%20%20document.body.removeChild(a);%20%20%20%20%20%20%20%20window.URL.revokeObjectURL(url);%20%20%20%20%20%20},%200);%20%20%20%20}%20%20}%20%20function%20getUniversalCdnUrl(cdnLink)%20{%20%20%20%20const%20cdn%20=%20new%20URL(cdnLink);%20%20%20%20cdn.host%20=%20%22scontent.cdninstagram.com%22;%20%20%20%20return%20cdn.href;%20%20}%20%20let%20all_urls%20=%20[];%20%20let%20after%20=%20%22%22;%20%20while%20(true)%20{%20%20%20%20console.log(%22FETCHING...%22);%20%20%20%20let%20data%20=%20await%20fetch(%20%20%20%20%20%20`https://www.instagram.com/graphql/query/?query_hash=396983faee97f4b49ccbe105b4daf7a0&variables={%22id%22:%22${user_id}%22,%22first%22:50,%22after%22:%22${after}%22}`%20%20%20%20);%20%20%20%20let%20json%20=%20await%20data.json();%20%20%20%20let%20edges%20=%20json?.data?.user?.edge_owner_to_timeline_media?.edges%20||%20[];%20%20%20%20console.log(`Found%20${edges?.length}%20medias.%20Processing...`);%20%20%20%20let%20urls%20=%20[];%20%20%20%20edges.forEach((e)%20=%3E%20{%20%20%20%20%20%20let%20childs%20=%20e.node?.edge_sidecar_to_children?.edges;%20%20%20%20%20%20if%20(childs)%20{%20%20%20%20%20%20%20%20urls.push(...childs.map((c)%20=%3E%20getBiggestMediaFromNode(c.node)));%20%20%20%20%20%20}%20else%20{%20%20%20%20%20%20%20%20urls.push(getBiggestMediaFromNode(e.node));%20%20%20%20%20%20}%20%20%20%20});%20%20%20%20all_urls.push(...urls);%20%20%20%20console.log(`Saved%20${urls.length}%20medias.%20(TOTAL:%20${all_urls.length})`);%20%20%20%20let%20pageInfo%20=%20json?.data?.user?.edge_owner_to_timeline_media?.page_info;%20%20%20%20if%20(pageInfo?.has_next_page)%20{%20%20%20%20%20%20after%20=%20pageInfo?.end_cursor;%20%20%20%20}%20else%20{%20%20%20%20%20%20console.log(%22[STOP]%20THIS%20IS%20THE%20LAST%20PAGE.%22);%20%20%20%20%20%20break;%20%20%20%20}%20%20}%20%20console.log(all_urls);%20%20download(all_urls.join(%22\\n%22),%20user_id,%20%22.txt%22);})();"
